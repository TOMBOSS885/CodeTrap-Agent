BASE_URL=https://api.example.com/v1
API_KEY=sk-your-key
MODELS=gpt-4.1

# Docker build mirrors. If your server can access Docker Hub, use python:3.12-slim.
PYTHON_IMAGE=docker.m.daocloud.io/library/python:3.12-slim
PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple

# Optional web protection. Login username is admin.
CODETRAP_PASSWORD=change-this-password

# Set to 1 only if your model API is intentionally on localhost/private network.
CODETRAP_ALLOW_PRIVATE_BASE_URL=0
